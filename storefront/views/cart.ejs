<%- include('layout', { title: 'Cart', step: 1, body: `
<h1 class="text-2xl font-bold text-gray-900 mb-6">Shopping Cart</h1>

<div class="grid md:grid-cols-3 gap-8">
  <div class="md:col-span-2 space-y-4">
    <!-- Cart item -->
    <div class="bg-white rounded-lg border border-gray-200 p-4 flex items-center gap-4">
      <div class="w-20 h-20 bg-gray-100 rounded flex items-center justify-center text-gray-400">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14" /></svg>
      </div>
      <div class="flex-1">
        <h3 class="font-medium text-gray-900">Wireless Bluetooth Headphones</h3>
        <p class="text-sm text-gray-500">Qty: 1</p>
      </div>
      <p class="text-lg font-bold text-gray-900">$79.99</p>
    </div>

    <!-- Promo code -->
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <label for="promo-input" class="block text-sm font-medium text-gray-700 mb-2">Promo Code</label>
      <div class="flex gap-2">
        <input type="text" id="promo-input" name="promo" placeholder="Enter code" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        <button id="apply-promo-btn" onclick="applyPromo()" class="px-4 py-2 bg-gray-800 text-white rounded-lg text-sm font-medium hover:bg-gray-700">Apply</button>
      </div>
      <div id="promo-result" class="hidden mt-2 text-sm"></div>
    </div>
  </div>

  <!-- Order summary -->
  <div class="bg-white rounded-lg border border-gray-200 p-6">
    <h2 class="font-bold text-gray-900 mb-4">Order Summary</h2>
    <div class="space-y-2 text-sm">
      <div class="flex justify-between"><span class="text-gray-600">Subtotal</span><span>$79.99</span></div>
      <div id="discount-line" class="hidden flex justify-between text-green-600"><span>Discount</span><span id="discount-amount"></span></div>
      <div class="flex justify-between"><span class="text-gray-600">Shipping</span><span class="text-gray-500">Calculated next</span></div>
      <hr class="my-2" />
      <div class="flex justify-between font-bold text-lg"><span>Total</span><span id="cart-total">$79.99</span></div>
    </div>
    <button onclick="proceedToCheckout()" class="w-full mt-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700 transition-colors">
      Proceed to Checkout
    </button>
  </div>
</div>

<script>
  function applyPromo() {
    const code = document.getElementById("promo-input").value.trim();
    fetch("/api/cart/promo", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ code })
    })
    .then(r => r.json())
    .then(data => {
      const result = document.getElementById("promo-result");
      result.classList.remove("hidden");
      if (data.success) {
        result.className = "mt-2 text-sm text-green-600";
        result.textContent = "Promo applied: " + data.label;

        // Store promo — the bug is that cart stores it as "promoCode"
        // but the review page (with bug active) reads "couponCode"
        sessionStorage.setItem("promoCode", JSON.stringify({
          code: code,
          discount: data.discount,
          label: data.label
        }));

        // Update display
        const subtotal = 79.99;
        const discountAmt = subtotal * data.discount;
        document.getElementById("discount-line").classList.remove("hidden");
        document.getElementById("discount-amount").textContent = "-$" + discountAmt.toFixed(2);
        document.getElementById("cart-total").textContent = "$" + (subtotal - discountAmt).toFixed(2);

        document.getElementById("apply-promo-btn").textContent = "Applied ✓";
        document.getElementById("apply-promo-btn").disabled = true;
        document.getElementById("promo-input").disabled = true;
      } else {
        result.className = "mt-2 text-sm text-red-600";
        result.textContent = data.message;
      }
    });
  }

  function proceedToCheckout() {
    window.location.href = "/shipping";
  }
</script>
` }) %>
