<%- include('layout', { title: 'Order Confirmed', step: 5, body: `
<div class="max-w-lg mx-auto text-center py-12">
  <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
    </svg>
  </div>
  <h1 class="text-2xl font-bold text-gray-900 mb-2">Order Confirmed!</h1>
  <p class="text-gray-600 mb-6">Thank you for your purchase.</p>
  <div class="bg-white rounded-lg border border-gray-200 p-6 text-left space-y-3">
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Order Number</span>
      <span id="order-number" class="font-mono font-medium text-gray-900"></span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Item</span>
      <span class="text-gray-900">Wireless Bluetooth Headphones</span>
    </div>
    <div class="flex justify-between text-sm">
      <span class="text-gray-500">Estimated Delivery</span>
      <span class="text-gray-900">3-5 business days</span>
    </div>
  </div>
  <a href="/" class="inline-block mt-8 px-6 py-3 bg-indigo-600 text-white rounded-lg font-medium hover:bg-indigo-700">
    Continue Shopping
  </a>
</div>

<script>
  document.getElementById("order-number").textContent = sessionStorage.getItem("orderId") || "ORD-" + Date.now();
  // Clear cart session
  sessionStorage.removeItem("cartItem");
  sessionStorage.removeItem("promoCode");
  sessionStorage.removeItem("shippingAddress");
  sessionStorage.removeItem("deliveryMethod");
  sessionStorage.removeItem("shippingFee");
  sessionStorage.removeItem("paymentInfo");
</script>
` }) %>
